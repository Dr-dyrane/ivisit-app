# Supabase Edge Functions local env
# Copy to: supabase/functions/.env

# Anthropic key for triage-copilot function
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Optional OpenAI key for demo-dispatch-reply. Falls back to Anthropic when unset.
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini

# Supabase edge runtime
SUPABASE_URL=your-supabase-url
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Provider discovery / media
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
GOOGLE_MAPS_ANDROID_API_KEY=your-google-maps-android-api-key
MAPBOX_ACCESS_TOKEN=your-mapbox-access-token
ENABLE_GOOGLE_PLACES=false
ENABLE_GOOGLE_GEOCODING=false

# Optional aliases accepted by local functions, useful when mirroring Expo env files
EXPO_PUBLIC_SUPABASE_URL=your-supabase-url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
EXPO_PUBLIC_SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=your-mapbox-access-token
EXPO_PUBLIC_ENABLE_GOOGLE_PLACES=false
EXPO_PUBLIC_ENABLE_GOOGLE_GEOCODING=false
