    "base64-arraybuffer": "^1.0.2",
    "date-fns": "^4.1.0",
    "expo": "~54.0.34",
    "expo-av": "^16.0.8",
    "expo-blur": "~15.0.8",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.9",
    "expo-contacts": "~15.0.11",
    "expo-font": "~14.0.8",
