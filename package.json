{
  "name": "ivisit",
  "version": "1.0.4",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web --output-dir dist && node scripts/postprocess_web_export.js dist",
    "vercel-build": "npm run build:web",
    "hardening:cleanup-apply": "node supabase/tests/scripts/cleanup_test_side_effects.js --apply",
    "hardening:cleanup-dry-run-guard": "node supabase/tests/scripts/assert_cleanup_dry_run_zero.js",
    "hardening:inventory-refresh": "node supabase/tests/scripts/export_live_schema_inventory.js",
    "hardening:inventory-guard": "node supabase/tests/scripts/assert_live_inventory_coverage.js",
    "hardening:rpc-authority-guard": "node supabase/tests/scripts/assert_rpc_authority_map.js",
    "hardening:finance-rpc-contract-guard": "node supabase/tests/scripts/assert_finance_rpc_contract.js",
    "hardening:automation-contract-guard": "node supabase/tests/scripts/assert_automation_contract.js",
    "hardening:cash-fee-contract-guard": "node supabase/tests/scripts/assert_cash_fee_deduction_contract.js",
    "hardening:governance-guards": "npm run hardening:inventory-guard && npm run hardening:rpc-authority-guard",
    "hardening:contract-matrix": "node supabase/tests/scripts/run_cross_repo_contract_matrix.js",
    "hardening:project-ref-guard": "node supabase/tests/scripts/assert_project_ref_alignment.js",
    "hardening:tip-rpc-sql-guard": "node supabase/tests/scripts/assert_tip_rpc_sql_guard.js",
    "hardening:contract-drift-guard": "npm run hardening:project-ref-guard && npm run hardening:contract-matrix && node supabase/tests/scripts/assert_contract_drift_zero.js && npm run hardening:tip-rpc-sql-guard",
    "hardening:console-ui-crud-matrix": "node supabase/tests/scripts/run_console_ui_crud_contract_matrix.js",
    "hardening:modal-domain-guard": "npm run hardening:console-ui-crud-matrix && node supabase/tests/scripts/assert_modal_domain_coverage.js",
    "hardening:table-flow-trace": "node supabase/tests/scripts/export_table_flow_trace.js --table emergency_requests",
    "hardening:high-profile-cta-trace": "node supabase/tests/scripts/run_high_profile_cta_trace_matrix.js",
    "hardening:table-field-runtime-coverage": "node supabase/tests/scripts/assert_table_field_runtime_coverage.js",
    "hardening:ambulances-surface-field-guard": "node supabase/tests/scripts/assert_ambulances_surface_field_guard.js",
    "hardening:doctors-surface-field-guard": "node supabase/tests/scripts/assert_doctors_surface_field_guard.js",
    "hardening:emergency-status-transitions-surface-field-guard": "node supabase/tests/scripts/assert_emergency_status_transitions_surface_field_guard.js",
    "hardening:insurance-surface-field-guard": "node supabase/tests/scripts/assert_insurance_surface_field_guard.js",
    "hardening:pricing-surface-field-guard": "node supabase/tests/scripts/assert_pricing_surface_field_guard.js",
    "hardening:medical-profiles-surface-field-guard": "node supabase/tests/scripts/assert_medical_profiles_surface_field_guard.js",
    "hardening:notifications-surface-field-guard": "node supabase/tests/scripts/assert_notifications_surface_field_guard.js",
    "hardening:visits-surface-field-guard": "node supabase/tests/scripts/assert_visits_surface_field_guard.js",
    "hardening:hospitals-surface-field-guard": "node supabase/tests/scripts/assert_hospitals_surface_field_guard.js",
    "hardening:organizations-surface-field-guard": "node supabase/tests/scripts/assert_organizations_surface_field_guard.js",
    "hardening:profiles-surface-field-guard": "node supabase/tests/scripts/assert_profiles_surface_field_guard.js",
    "hardening:preferences-surface-field-guard": "node supabase/tests/scripts/assert_preferences_surface_field_guard.js",
    "hardening:admin-audit-log-surface-field-guard": "node supabase/tests/scripts/assert_admin_audit_log_surface_field_guard.js",
    "hardening:user-sessions-surface-field-guard": "node supabase/tests/scripts/assert_user_sessions_surface_field_guard.js",
    "hardening:id-mappings-surface-field-guard": "node supabase/tests/scripts/assert_id_mappings_surface_field_guard.js",
    "hardening:user-activity-surface-field-guard": "node supabase/tests/scripts/assert_user_activity_surface_field_guard.js",
    "hardening:support-tickets-surface-field-guard": "node supabase/tests/scripts/assert_support_tickets_surface_field_guard.js",
    "hardening:support-faqs-surface-field-guard": "node supabase/tests/scripts/assert_support_faqs_surface_field_guard.js",
    "hardening:search-history-surface-field-guard": "node supabase/tests/scripts/assert_search_history_surface_field_guard.js",
    "hardening:search-selections-surface-field-guard": "node supabase/tests/scripts/assert_search_selections_surface_field_guard.js",
    "hardening:search-events-surface-field-guard": "node supabase/tests/scripts/assert_search_events_surface_field_guard.js",
    "hardening:trending-topics-surface-field-guard": "node supabase/tests/scripts/assert_trending_topics_surface_field_guard.js",
    "hardening:subscribers-surface-field-guard": "node supabase/tests/scripts/assert_subscribers_surface_field_guard.js",
    "hardening:health-news-surface-field-guard": "node supabase/tests/scripts/assert_health_news_surface_field_guard.js",
    "hardening:organization-wallets-surface-field-guard": "node supabase/tests/scripts/assert_organization_wallets_surface_field_guard.js",
    "hardening:patient-wallets-surface-field-guard": "node supabase/tests/scripts/assert_patient_wallets_surface_field_guard.js",
    "hardening:ivisit-main-wallet-surface-field-guard": "node supabase/tests/scripts/assert_ivisit_main_wallet_surface_field_guard.js",
    "hardening:emergency-requests-surface-field-guard": "node supabase/tests/scripts/assert_emergency_requests_surface_field_guard.js",
    "hardening:payment-methods-surface-field-guard": "node supabase/tests/scripts/assert_payment_methods_surface_field_guard.js",
    "hardening:wallet-ledger-surface-field-guard": "node supabase/tests/scripts/assert_wallet_ledger_surface_field_guard.js",
    "hardening:payments-surface-field-guard": "node supabase/tests/scripts/assert_payments_surface_field_guard.js",
    "hardening:visits-runtime-confidence-assert": "node supabase/tests/scripts/assert_visits_runtime_confidence.js",
    "hardening:visits-runtime-confidence": "node supabase/tests/scripts/run_e2e_flow_matrix.js && npm run hardening:visits-runtime-confidence-assert",
    "hardening:emergency-runtime-confidence-assert": "node supabase/tests/scripts/assert_emergency_runtime_confidence.js",
    "hardening:emergency-runtime-confidence": "npm run hardening:console-matrix && node supabase/tests/scripts/run_e2e_flow_matrix.js && npm run hardening:emergency-runtime-confidence-assert",
    "hardening:emergency": "node supabase/tests/scripts/validate_emergency_hardening_guards.js",
    "hardening:console-matrix": "node supabase/tests/scripts/run_console_transition_matrix.js",
    "hardening:cash-matrix": "node supabase/tests/scripts/run_cash_role_isolation_matrix.js",
    "hardening:mutation-matrix": "node supabase/tests/scripts/run_mutation_role_isolation_matrix.js",
    "hardening:runtime-crud-batch": "node supabase/tests/scripts/run_runtime_crud_relationship_batch.js",
    "hardening:targeted-matrix-guard": "npm run hardening:console-ui-crud-matrix && npm run hardening:runtime-crud-batch && node supabase/tests/scripts/assert_targeted_matrix_coverage.js",
    "hardening:runtime-data-integrity": "node supabase/tests/scripts/assert_runtime_data_integrity.js",
    "hardening:runtime-data-repair": "node supabase/tests/scripts/repair_runtime_data_integrity.js",
    "hardening:full": "npm run hardening:cleanup-dry-run-guard && npm run hardening:governance-guards && npm run hardening:contract-drift-guard && npm run hardening:console-ui-crud-matrix && npm run hardening:emergency && npm run hardening:console-matrix && npm run hardening:cash-matrix && npm run hardening:mutation-matrix && node supabase/tests/scripts/run_e2e_flow_matrix.js && npm run hardening:emergency-runtime-confidence-assert && npm run hardening:visits-runtime-confidence-assert && npm run hardening:runtime-data-integrity && npm run hardening:cleanup-apply && npm run hardening:cleanup-dry-run-guard && npm run hardening:governance-guards && npm run hardening:contract-drift-guard"
  },
