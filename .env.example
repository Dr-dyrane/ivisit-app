# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google Maps Configuration
# Used for hospital discovery and route tracking
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
GOOGLE_MAPS_ANDROID_API_KEY=your-google-maps-android-api-key

# Stripe Configuration
# Publishable key for the mobile app to initialize the payment sheet
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key

# Gumroad Configuration
# Direct link to the insurance plan product on Gumroad
EXPO_PUBLIC_GUMROAD_PRODUCT_URL=https://ivisit.gumroad.com/l/insurance-basic

# App Configuration
EXPO_PUBLIC_DEBUG_MODE=false
EXPO_PUBLIC_WEB_APP_URL=https://app.ivisit.ng

# AI Triage UX
# Enable AI phrasing for triage questions in the app (calls Supabase Edge Function)
EXPO_PUBLIC_ENABLE_TRIAGE_AI=false

# Server-side only (DO NOT expose as EXPO_PUBLIC_)
# Used by local scripts and server-side operations only
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Used by Supabase Edge Function: supabase/functions/triage-copilot
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
