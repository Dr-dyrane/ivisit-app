# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google Maps Configuration
# Google Maps SDK keys are still used for map rendering.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
GOOGLE_MAPS_ANDROID_API_KEY=your-google-maps-android-api-key
# Cost controls for Google web services. Places is enabled for Explore Care
# provider discovery; geocoding remains off unless explicitly needed.
EXPO_PUBLIC_ENABLE_GOOGLE_PLACES=true
EXPO_PUBLIC_ENABLE_GOOGLE_GEOCODING=false

# Stripe Configuration
# Publishable key for the mobile app to initialize the payment sheet
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key

# Gumroad Configuration
# Direct link to the insurance plan product on Gumroad
EXPO_PUBLIC_GUMROAD_PRODUCT_URL=https://ivisit.gumroad.com/l/insurance-basic

# App Configuration
EXPO_PUBLIC_DEBUG_MODE=false
EXPO_PUBLIC_WEB_APP_URL=https://app.ivisit.ng

# AI Triage UX
# Enable AI phrasing for triage questions in the app (calls Supabase Edge Function)
EXPO_PUBLIC_ENABLE_TRIAGE_AI=false

# Google Play / app review emergency-flow sign-in
# App-side flag only. The static OTP itself must stay server-side in Edge Function secrets.
EXPO_PUBLIC_REVIEW_DEMO_AUTH_ENABLED=false
EXPO_PUBLIC_REVIEW_DEMO_AUTH_EMAIL=support@ivisit.ng

# Server-side only (DO NOT expose as EXPO_PUBLIC_)
# Used by local scripts and server-side operations only
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Used by Supabase Edge Function: supabase/functions/review-demo-auth
REVIEW_DEMO_AUTH_ENABLED=false
REVIEW_DEMO_AUTH_EMAIL=support@ivisit.ng
REVIEW_DEMO_AUTH_OTP=123456
# Edge-function Google web-service cost controls.
ENABLE_GOOGLE_PLACES=true
ENABLE_GOOGLE_GEOCODING=false
# Used by Supabase Edge Function: supabase/functions/triage-copilot
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# Optional for Supabase Edge Function: supabase/functions/demo-dispatch-reply
# If unset, demo dispatch replies use Anthropic first, then a canned fallback.
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini
