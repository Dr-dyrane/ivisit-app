# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google Maps Configuration
# Used for hospital discovery and route tracking
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
GOOGLE_MAPS_ANDROID_API_KEY=your-google-maps-android-api-key

# Stripe Configuration
# Publishable key for the mobile app to initialize the payment sheet
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key

# Gumroad Configuration
# Direct link to the insurance plan product on Gumroad
EXPO_PUBLIC_GUMROAD_PRODUCT_URL=https://ivisit.gumroad.com/l/insurance-basic

# App Configuration
EXPO_PUBLIC_DEBUG_MODE=false